.admin-page {
  padding-bottom: 56rpx;
}

.state-card {
  padding: 34rpx;
}

.state-title,
.admin-title {
  color: #27302b;
  font-size: 36rpx;
  font-weight: 900;
}

.state-desc,
.admin-desc {
  margin-top: 16rpx;
  color: #69746e;
  font-size: 26rpx;
  line-height: 1.6;
}

.admin-hero {
  padding: 38rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(247, 181, 160, 0.35), rgba(210, 226, 215, 0.72)),
    #fffdf8;
  box-shadow: 0 18rpx 42rpx rgba(82, 121, 111, 0.1);
}

.admin-entry-grid {
  display: grid;
  gap: 22rpx;
  margin-top: 26rpx;
}

.admin-entry {
  padding: 32rpx;
  border: 1rpx solid rgba(82, 121, 111, 0.12);
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(52, 72, 66, 0.08);
}

.admin-entry.primary {
  background: #52796f;
}

.entry-title {
  color: #27302b;
  font-size: 32rpx;
  font-weight: 900;
}

.entry-desc {
  margin-top: 12rpx;
  color: #69746e;
  font-size: 25rpx;
  line-height: 1.5;
}

.admin-entry.primary .entry-title,
.admin-entry.primary .entry-desc {
  color: #ffffff;
}

.primary-button {
  margin-top: 30rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: #52796f;
  font-size: 28rpx;
  font-weight: 800;
}
