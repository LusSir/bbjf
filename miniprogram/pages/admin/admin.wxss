.admin-page {
  padding-bottom: 56rpx;
}

.state-card,
.manage-card {
  padding: 34rpx;
}

.state-title,
.admin-title {
  color: #27302b;
  font-size: 36rpx;
  font-weight: 900;
}

.state-desc,
.admin-desc,
.manage-desc {
  margin-top: 16rpx;
  color: #69746e;
  font-size: 26rpx;
  line-height: 1.6;
}

.admin-hero {
  padding: 38rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(247, 181, 160, 0.35), rgba(210, 226, 215, 0.72)),
    #fffdf8;
  box-shadow: 0 18rpx 42rpx rgba(82, 121, 111, 0.1);
}

.primary-button {
  margin-top: 30rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: #52796f;
  font-size: 28rpx;
  font-weight: 800;
}

.secondary-button {
  margin-top: 30rpx;
  border-radius: 18rpx;
  color: #52796f;
  background: #eef5ef;
  font-size: 28rpx;
  font-weight: 800;
}

.form-field {
  margin-top: 24rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #4c5650;
  font-size: 25rpx;
  font-weight: 800;
}

.field-input,
.field-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #f8f7f3;
  color: #27302b;
  font-size: 26rpx;
}

.field-input {
  min-height: 84rpx;
  padding: 0 22rpx;
}

.field-textarea {
  min-height: 150rpx;
  padding: 18rpx 22rpx;
  line-height: 1.5;
}

.picker-value {
  display: flex;
  align-items: center;
}

.image-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.form-image,
.image-placeholder {
  width: 160rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #f8f7f3;
}

.image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7b786f;
  font-size: 24rpx;
}

.small-button,
.mini-button {
  margin: 0;
  border-radius: 14rpx;
  color: #52796f;
  background: #eef5ef;
  font-size: 24rpx;
  font-weight: 800;
}

.switch-grid {
  display: grid;
  gap: 14rpx;
  margin-top: 24rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #4c5650;
  font-size: 26rpx;
}

.inline-field {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.inline-field .field-label {
  margin-bottom: 0;
}

.short-input {
  width: 180rpx;
}

.form-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.admin-product {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf0eb;
}

.admin-product:last-child {
  border-bottom: 0;
}

.admin-product-image {
  flex: 0 0 auto;
  width: 112rpx;
  height: 86rpx;
  border-radius: 14rpx;
  background: #f8f7f3;
}

.admin-product-main {
  flex: 1;
  min-width: 0;
}

.admin-product-name {
  color: #27302b;
  font-size: 27rpx;
  font-weight: 900;
}

.admin-product-meta {
  margin-top: 6rpx;
  color: #7b786f;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.admin-product-actions {
  display: flex;
  gap: 10rpx;
}

.mini-button {
  padding: 0 18rpx;
  line-height: 58rpx;
}

.mini-button.danger {
  color: #df765d;
  background: #fff1ec;
}
