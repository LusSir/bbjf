.products-page {
  height: 100vh;
  padding: 0;
  overflow: hidden;
  box-sizing: border-box;
}

.products-layout {
  display: grid;
  grid-template-columns: 176rpx minmax(0, 1fr);
  height: 100vh;
  box-sizing: border-box;
  overflow: hidden;
}

.category-sidebar {
  height: 100vh;
  padding: 22rpx 12rpx 32rpx;
  background: #e8f0e9;
  box-sizing: border-box;
}

.category-tab {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 84rpx;
  margin-bottom: 12rpx;
  padding: 0 16rpx 0 20rpx;
  border-radius: 14rpx;
  background: transparent;
  color: #607067;
  box-sizing: border-box;
}

.category-tab.active {
  background: #ffffff;
  color: #4f7669;
  box-shadow: 0 8rpx 18rpx rgba(43, 59, 52, 0.08);
}

.category-tab.active::before {
  content: "";
  position: absolute;
  left: 0;
  top: 22rpx;
  bottom: 22rpx;
  width: 6rpx;
  border-radius: 999rpx;
  background: #4f7669;
}

.category-name {
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.25;
}

.product-content {
  display: flex;
  flex-direction: column;
  min-width: 0;
  height: 100vh;
  padding: 24rpx 22rpx 56rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #26302a;
  font-size: 25rpx;
  box-sizing: border-box;
}

.search-clear {
  flex: 0 0 auto;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #e8f0e9;
  color: #4f7669;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 68rpx;
}

.product-scroll {
  flex: 1;
  width: 100%;
  min-height: 0;
  overflow: hidden;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  width: 100%;
  box-sizing: border-box;
}

.empty {
  margin-top: 6rpx;
  padding: 48rpx 30rpx;
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #26302a;
}

.empty-desc {
  margin-top: 12rpx;
  color: #6f7a72;
  font-size: 24rpx;
  line-height: 1.6;
}
