.products-page {
  height: 100vh;
  padding: 0;
  overflow: hidden;
  box-sizing: border-box;
}

.products-layout {
  display: grid;
  grid-template-columns: 176rpx 1fr;
  height: 100vh;
  box-sizing: border-box;
}

.category-sidebar {
  height: 100vh;
  padding: 22rpx 12rpx 32rpx;
  background: #f0f5f0;
  box-sizing: border-box;
}

.category-tab {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 84rpx;
  margin-bottom: 12rpx;
  padding: 0 16rpx 0 20rpx;
  border-radius: 18rpx;
  background: transparent;
  color: #5d6962;
  box-sizing: border-box;
}

.category-tab.active {
  background: #ffffff;
  color: #52796f;
  box-shadow: 0 10rpx 24rpx rgba(82, 121, 111, 0.12);
}

.category-tab.active::before {
  content: "";
  position: absolute;
  left: 0;
  top: 22rpx;
  bottom: 22rpx;
  width: 6rpx;
  border-radius: 999rpx;
  background: #52796f;
}

.category-name {
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.25;
}

.product-content {
  height: 100vh;
  padding: 24rpx 22rpx 56rpx;
  box-sizing: border-box;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.empty {
  margin-top: 6rpx;
  padding: 48rpx 30rpx;
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #27302b;
}

.empty-desc {
  margin-top: 12rpx;
  color: #7b786f;
  font-size: 24rpx;
  line-height: 1.6;
}
