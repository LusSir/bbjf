.products-page {
  padding-bottom: 56rpx;
}

.category-tabs {
  white-space: nowrap;
  margin: -4rpx -24rpx 28rpx;
  padding: 4rpx 24rpx 14rpx;
  box-sizing: border-box;
}

.category-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  margin-right: 14rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #5d6962;
  font-size: 26rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 22rpx rgba(52, 72, 66, 0.06);
}

.category-tab.active {
  background: #52796f;
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(82, 121, 111, 0.2);
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.empty {
  padding: 48rpx 30rpx;
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #27302b;
}

.empty-desc {
  margin-top: 12rpx;
  color: #7b786f;
  font-size: 24rpx;
  line-height: 1.6;
}
