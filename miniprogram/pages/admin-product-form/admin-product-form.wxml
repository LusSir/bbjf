<view class="page product-form-page">
  <view wx:if="{{checking || loading}}" class="card state-card">
    <view class="state-title">{{checking ? '正在校验权限' : '正在加载商品'}}</view>
  </view>

  <view wx:elif="{{!allowed}}" class="card state-card">
    <view class="state-title">无法编辑商品</view>
    <view class="state-desc">当前微信账号不是管理员。</view>
  </view>

  <view wx:else class="card form-card">
    <view class="section-title">{{editingId ? '编辑商品' : '新增商品'}}</view>

    <view class="form-field">
      <view class="field-label">商品名称</view>
      <input class="field-input" value="{{form.name}}" data-field="name" bindinput="updateField" placeholder="纯棉四件套" />
    </view>

    <view class="form-field">
      <view class="field-label">商品分类</view>
      <picker range="{{categories}}" range-key="name" bindchange="changeCategory">
        <view class="field-input picker-value">{{selectedCategoryName}}</view>
      </picker>
    </view>

    <view class="form-field">
      <view class="field-label">价格文案</view>
      <input class="field-input" value="{{form.priceText}}" data-field="priceText" bindinput="updateField" placeholder="¥199 起 / 到店咨询价" />
    </view>

    <view class="form-field">
      <view class="field-label">花色图片</view>
      <view class="image-header">
        <view class="image-help">第一张会自动作为主图，也可手动设为主图。</view>
        <button class="small-button" loading="{{uploading}}" bindtap="chooseImage">上传图片</button>
      </view>
      <view wx:if="{{!form.images.length}}" class="image-empty">还没有上传花色图</view>
      <view wx:for="{{form.images}}" wx:key="url" class="color-image-row">
        <image class="form-image" src="{{item.displayUrl || item.url}}" mode="aspectFill" />
        <view class="color-image-main">
          <input class="color-name-input" value="{{item.name}}" data-index="{{index}}" bindinput="updateImageName" placeholder="花色名称，如：米白小花" />
          <view class="image-actions">
            <button class="tiny-button {{form.image === item.url ? 'active' : ''}}" data-index="{{index}}" bindtap="setPrimaryImage">
              {{form.image === item.url ? '主图' : '设主图'}}
            </button>
            <button class="tiny-button danger" data-index="{{index}}" bindtap="removeProductImage">删除</button>
          </view>
        </view>
      </view>
    </view>

    <view class="form-field">
      <view class="image-header">
        <view>
          <view class="field-label">商品规格</view>
          <view class="image-help">用于购物车下单，至少保留一个启用规格。</view>
        </view>
        <button class="small-button" bindtap="addSku">新增规格</button>
      </view>
      <view wx:for="{{form.skus}}" wx:for-item="sku" wx:for-index="skuIndex" wx:key="id" class="sku-edit-card">
        <view class="sku-edit-head">
          <view class="sku-edit-title">规格 {{skuIndex + 1}}</view>
          <switch checked="{{sku.status === 'active'}}" data-index="{{skuIndex}}" bindchange="updateSkuStatus" color="#4f7669" />
        </view>
        <view class="sku-edit-grid">
          <input class="field-input" value="{{sku.colorName}}" data-index="{{skuIndex}}" data-field="colorName" bindinput="updateSkuField" placeholder="花色名" />
          <input class="field-input" value="{{sku.size}}" data-index="{{skuIndex}}" data-field="size" bindinput="updateSkuField" placeholder="尺寸，如 1.5m / 1.8m" />
          <input class="field-input" value="{{sku.priceText}}" data-index="{{skuIndex}}" data-field="priceText" bindinput="updateSkuField" placeholder="价格文案" />
          <input class="field-input" value="{{sku.stockText}}" data-index="{{skuIndex}}" data-field="stockText" bindinput="updateSkuField" placeholder="库存说明" />
        </view>
        <view class="sku-image-picker">
          <view class="sku-image-top">
            <view>
              <view class="sku-image-label">规格图片</view>
              <view class="sku-image-help">从已上传花色图中选择，保存时自动关联图片。</view>
            </view>
            <view class="sku-image-actions">
              <button class="tiny-button" data-index="{{skuIndex}}" bindtap="useSkuMainImage">用主图</button>
              <button class="tiny-button" data-index="{{skuIndex}}" bindtap="clearSkuImage">清除</button>
            </view>
          </view>
          <scroll-view wx:if="{{form.images.length}}" class="sku-image-scroll" scroll-x enable-flex>
            <view
              wx:for="{{form.images}}"
              wx:for-item="imageItem"
              wx:for-index="imageIndex"
              wx:key="url"
              class="sku-image-option {{sku.image === imageItem.url ? 'active' : ''}}"
              data-sku-index="{{skuIndex}}"
              data-image-index="{{imageIndex}}"
              bindtap="selectSkuImage"
            >
              <image class="sku-image-thumb" src="{{imageItem.displayUrl || imageItem.url}}" mode="aspectFill" />
              <view class="sku-image-name">{{imageItem.name || '花色图'}}</view>
            </view>
          </scroll-view>
          <view wx:else class="sku-image-empty">先上传花色图后再选择规格图片</view>
        </view>
        <view class="sku-edit-foot">
          <input class="field-input short-input sku-sort-input" type="number" value="{{sku.sort}}" data-index="{{skuIndex}}" data-field="sort" bindinput="updateSkuField" placeholder="排序" />
          <button class="tiny-button danger" data-index="{{skuIndex}}" bindtap="removeSku">删除规格</button>
        </view>
      </view>
    </view>

    <view class="form-field">
      <view class="field-label">标签</view>
      <textarea class="field-textarea" value="{{form.tagsText}}" data-field="tagsText" bindinput="updateField" placeholder="一行一个，例如：热卖" />
    </view>

    <view class="form-field">
      <view class="field-label">产品卖点</view>
      <textarea class="field-textarea" value="{{form.highlightsText}}" data-field="highlightsText" bindinput="updateField" placeholder="一行一个卖点" />
    </view>

    <view class="form-field">
      <view class="field-label">规格信息</view>
      <textarea class="field-textarea" value="{{form.specsText}}" data-field="specsText" bindinput="updateField" placeholder="一行一个规格" />
    </view>

    <view class="form-field">
      <view class="field-label">产品说明</view>
      <textarea class="field-textarea" value="{{form.description}}" data-field="description" bindinput="updateField" placeholder="适合日常家用，到店可看实物" />
    </view>

    <view class="switch-grid">
      <label class="switch-row">
        <text>首页推荐</text>
        <switch checked="{{form.isFeatured}}" data-field="isFeatured" bindchange="updateSwitch" color="#4f7669" />
      </label>
      <label class="switch-row">
        <text>特价</text>
        <switch checked="{{form.isSpecial}}" data-field="isSpecial" bindchange="updateSwitch" color="#4f7669" />
      </label>
      <label class="switch-row">
        <text>新品</text>
        <switch checked="{{form.isNew}}" data-field="isNew" bindchange="updateSwitch" color="#4f7669" />
      </label>
    </view>

    <view class="form-field sort-card">
      <view class="sort-copy">
        <view class="field-label">排序</view>
        <view class="sort-help">数字越小越靠前，默认 999</view>
      </view>
      <input class="field-input sort-input" type="number" value="{{form.sort}}" data-field="sort" bindinput="updateField" />
    </view>

    <button class="primary-button" loading="{{saving}}" bindtap="saveProduct">保存商品</button>
  </view>
</view>
