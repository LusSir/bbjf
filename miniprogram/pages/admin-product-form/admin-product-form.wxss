.product-form-page {
  padding-bottom: 56rpx;
}

.state-card,
.form-card {
  padding: 34rpx;
}

.state-title {
  color: #26302a;
  font-size: 32rpx;
  font-weight: 900;
}

.state-desc {
  margin-top: 12rpx;
  color: #5f6f66;
  font-size: 25rpx;
  line-height: 1.5;
}

.section-title {
  color: #26302a;
  font-size: 34rpx;
  font-weight: 900;
}

.form-field {
  margin-top: 24rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #43564d;
  font-size: 25rpx;
  font-weight: 800;
}

.field-input,
.field-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #f4f6f1;
  color: #26302a;
  font-size: 26rpx;
}

.field-input {
  min-height: 84rpx;
  padding: 0 22rpx;
}

.field-textarea {
  min-height: 150rpx;
  padding: 18rpx 22rpx;
  line-height: 1.5;
}

.picker-value {
  display: flex;
  align-items: center;
}

.image-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.image-help {
  flex: 1;
  color: #6f7a72;
  font-size: 24rpx;
  line-height: 1.45;
}

.image-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 116rpx;
  margin-top: 16rpx;
  border-radius: 16rpx;
  background: #f4f6f1;
  color: #6f7a72;
  font-size: 25rpx;
}

.color-image-row {
  display: flex;
  gap: 18rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f4f6f1;
}

.form-image {
  flex: 0 0 auto;
  width: 160rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #ffffff;
}

.color-image-main {
  flex: 1;
  min-width: 0;
}

.color-name-input {
  height: 58rpx;
  padding: 0 16rpx;
  border-radius: 14rpx;
  background: #ffffff;
  color: #26302a;
  font-size: 25rpx;
}

.image-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.small-button,
.tiny-button {
  margin: 0;
  border-radius: 14rpx;
  color: #4f7669;
  background: #e8f0e9;
  font-size: 24rpx;
  font-weight: 800;
}

.tiny-button {
  padding: 0 18rpx;
  line-height: 54rpx;
}

.tiny-button.active {
  color: #ffffff;
  background: #4f7669;
}

.tiny-button.danger {
  color: #d96f57;
  background: #fff0eb;
}

.sku-edit-card {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f7f4ef;
}

.sku-edit-head,
.sku-edit-foot,
.sku-image-line {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.sku-edit-head {
  justify-content: space-between;
}

.sku-edit-title {
  color: #26302a;
  font-size: 26rpx;
  font-weight: 900;
}

.sku-edit-grid {
  display: grid;
  gap: 12rpx;
  margin-top: 14rpx;
}

.sku-image-line,
.sku-edit-foot {
  margin-top: 12rpx;
}

.sku-image-input {
  flex: 1;
  min-width: 0;
}

.switch-grid {
  display: grid;
  gap: 14rpx;
  margin-top: 24rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #43564d;
  font-size: 26rpx;
}

.inline-field {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.inline-field .field-label {
  margin-bottom: 0;
}

.short-input {
  width: 180rpx;
}

.primary-button {
  margin-top: 30rpx;
  border-radius: 16rpx;
  color: #ffffff;
  background: #4f7669;
  font-size: 28rpx;
  font-weight: 800;
}
