.product-form-page {
  padding-bottom: 56rpx;
}

.state-card,
.form-card {
  padding: 34rpx;
}

.state-title {
  color: #26302a;
  font-size: 32rpx;
  font-weight: 900;
}

.state-desc {
  margin-top: 12rpx;
  color: #5f6f66;
  font-size: 25rpx;
  line-height: 1.5;
}

.section-title {
  color: #26302a;
  font-size: 34rpx;
  font-weight: 900;
}

.form-field {
  margin-top: 24rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #43564d;
  font-size: 25rpx;
  font-weight: 800;
}

.field-input,
.field-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #f4f6f1;
  color: #26302a;
  font-size: 26rpx;
}

.field-input {
  min-height: 84rpx;
  padding: 0 22rpx;
}

.field-textarea {
  min-height: 150rpx;
  padding: 18rpx 22rpx;
  line-height: 1.5;
}

.picker-value {
  display: flex;
  align-items: center;
}

.image-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.image-help {
  flex: 1;
  color: #6f7a72;
  font-size: 24rpx;
  line-height: 1.45;
}

.image-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 116rpx;
  margin-top: 16rpx;
  border-radius: 16rpx;
  background: #f4f6f1;
  color: #6f7a72;
  font-size: 25rpx;
}

.color-image-row {
  display: flex;
  gap: 18rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f4f6f1;
}

.form-image {
  flex: 0 0 auto;
  width: 160rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #ffffff;
}

.color-image-main {
  flex: 1;
  min-width: 0;
}

.color-name-input {
  height: 58rpx;
  padding: 0 16rpx;
  border-radius: 14rpx;
  background: #ffffff;
  color: #26302a;
  font-size: 25rpx;
}

.image-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.small-button,
.tiny-button {
  margin: 0;
  border-radius: 14rpx;
  color: #4f7669;
  background: #e8f0e9;
  font-size: 24rpx;
  font-weight: 800;
}

.tiny-button {
  padding: 0 18rpx;
  line-height: 54rpx;
}

.tiny-button.active {
  color: #ffffff;
  background: #4f7669;
}

.tiny-button.danger {
  color: #d96f57;
  background: #fff0eb;
}

.sku-edit-card {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f7f4ef;
}

.sku-edit-head,
.sku-edit-foot,
.sku-image-line {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.sku-edit-head {
  justify-content: space-between;
}

.sku-edit-title {
  color: #26302a;
  font-size: 26rpx;
  font-weight: 900;
}

.sku-edit-grid {
  display: grid;
  gap: 12rpx;
  margin-top: 14rpx;
}

.sku-image-line,
.sku-edit-foot {
  margin-top: 12rpx;
}

.sku-image-input {
  flex: 1;
  min-width: 0;
}

.sku-image-picker {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #ffffff;
}

.sku-image-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.sku-image-label {
  color: #43564d;
  font-size: 24rpx;
  font-weight: 900;
}

.sku-image-help {
  margin-top: 4rpx;
  color: #6f7a72;
  font-size: 22rpx;
  line-height: 1.35;
}

.sku-image-actions {
  display: flex;
  gap: 10rpx;
}

.sku-image-scroll {
  margin-top: 14rpx;
  white-space: nowrap;
}

.sku-image-option {
  display: inline-block;
  width: 132rpx;
  margin-right: 14rpx;
  padding: 8rpx;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  background: #f4f6f1;
  vertical-align: top;
}

.sku-image-option.active {
  border-color: #4f7669;
  background: #e8f0e9;
}

.sku-image-thumb {
  width: 112rpx;
  height: 88rpx;
  border-radius: 12rpx;
  background: #ffffff;
}

.sku-image-name {
  margin-top: 6rpx;
  color: #43564d;
  font-size: 21rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sku-image-empty {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f4f6f1;
  color: #6f7a72;
  font-size: 23rpx;
  text-align: center;
}

.switch-grid {
  display: grid;
  gap: 14rpx;
  margin-top: 24rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #43564d;
  font-size: 26rpx;
}

.inline-field {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.inline-field .field-label {
  margin-bottom: 0;
}

.short-input {
  width: 180rpx;
}

.sku-sort-input {
  width: 150rpx;
  text-align: center;
}

.sort-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 22rpx;
  border: 2rpx solid rgba(79, 118, 105, 0.14);
  border-radius: 18rpx;
  background: #f7f4ef;
}

.sort-copy {
  flex: 1;
  min-width: 0;
}

.sort-copy .field-label {
  margin-bottom: 6rpx;
}

.sort-help {
  color: #6f7a72;
  font-size: 23rpx;
  line-height: 1.35;
}

.sort-input {
  flex: 0 0 150rpx;
  width: 150rpx;
  min-height: 72rpx;
  padding: 0 12rpx;
  background: #ffffff;
  color: #4f7669;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
}

.primary-button {
  margin-top: 30rpx;
  border-radius: 16rpx;
  color: #ffffff;
  background: #4f7669;
  font-size: 28rpx;
  font-weight: 800;
}
