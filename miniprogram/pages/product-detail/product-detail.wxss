.detail-page {
  padding-bottom: 150rpx;
}

.detail-cover {
  position: relative;
  display: flex;
  align-items: flex-start;
  min-height: 420rpx;
  padding: 24rpx;
  overflow: hidden;
  border-radius: 16rpx;
  box-sizing: border-box;
  box-shadow: 0 14rpx 34rpx rgba(43, 59, 52, 0.08);
}

.detail-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.tone-warm { background: linear-gradient(135deg, #f5ddd1, #e7efe7); }
.tone-deep { background: linear-gradient(135deg, #dfe8dc, #7fa396); }
.tone-soft { background: linear-gradient(135deg, #f7e4dd, #e9b9a9); }
.tone-rose { background: linear-gradient(135deg, #f4d9d3, #c99392); }
.tone-green { background: linear-gradient(135deg, #e2ede2, #8ea99d); }
.tone-red { background: linear-gradient(135deg, #f3cbc0, #cc7567); }
.tone-gold { background: linear-gradient(135deg, #f5e4bd, #e4b06f); }

.detail-tag {
  position: relative;
  z-index: 1;
  margin-right: 12rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.84);
  color: #4f7669;
  font-size: 24rpx;
  font-weight: 800;
}

.detail-main {
  margin-top: 20rpx;
  padding: 30rpx;
}

.detail-name {
  color: #26302a;
  font-size: 40rpx;
  font-weight: 800;
}

.detail-price {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff0eb;
  color: #d96f57;
  font-size: 34rpx;
  font-weight: 800;
}

.detail-price.special {
  background: #fff4d8;
  color: #b86f26;
}

.detail-note {
  margin-top: 12rpx;
  color: #6f7a72;
  font-size: 24rpx;
}

.detail-section {
  padding: 30rpx;
}

.list-item {
  margin-top: 16rpx;
  color: #43564d;
  font-size: 27rpx;
  line-height: 1.55;
}

.color-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.color-card {
  display: inline-block;
  width: 220rpx;
  margin-right: 18rpx;
  vertical-align: top;
}

.color-image {
  width: 220rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #f4f6f1;
}

.color-image-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 18rpx;
  color: #6f7a72;
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
  white-space: normal;
}

.color-name {
  margin-top: 10rpx;
  color: #43564d;
  font-size: 24rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.description {
  margin-top: 14rpx;
  color: #43564d;
  font-size: 27rpx;
  line-height: 1.65;
}

.sku-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.sku-card {
  padding: 18rpx;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  background: #f4f6f1;
}

.sku-card.active {
  border-color: #4f7669;
  background: #eaf3ed;
}

.sku-card.disabled {
  opacity: 0.45;
}

.sku-title {
  color: #24352e;
  font-size: 25rpx;
  font-weight: 900;
}

.sku-meta {
  margin-top: 6rpx;
  color: #6f7a72;
  font-size: 22rpx;
  line-height: 1.35;
}

.quantity-line {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
}

.quantity-label {
  color: #4e5b54;
  font-size: 25rpx;
  font-weight: 800;
}

.quantity-input {
  width: 120rpx;
  height: 64rpx;
  border-radius: 14rpx;
  background: #f4f6f1;
  color: #24352e;
  text-align: center;
}

.cart-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 18rpx;
}

.cart-button {
  margin: 0;
  border-radius: 16rpx;
  color: #4f7669;
  background: #eaf3ed;
  font-size: 26rpx;
  font-weight: 900;
}

.cart-button.primary {
  color: #ffffff;
  background: #4f7669;
}
