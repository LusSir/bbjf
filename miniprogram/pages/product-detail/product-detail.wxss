.detail-page {
  padding-bottom: 150rpx;
}

.detail-cover {
  position: relative;
  display: flex;
  align-items: flex-start;
  min-height: 420rpx;
  padding: 24rpx;
  overflow: hidden;
  border-radius: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 18rpx 42rpx rgba(82, 121, 111, 0.1);
}

.detail-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.tone-warm { background: linear-gradient(135deg, #f8d7c8, #e9efe7); }
.tone-deep { background: linear-gradient(135deg, #dfe9df, #86a99d); }
.tone-soft { background: linear-gradient(135deg, #f8e3de, #f3b7a6); }
.tone-rose { background: linear-gradient(135deg, #f7d8d0, #d99b9a); }
.tone-green { background: linear-gradient(135deg, #e5efe5, #91b3a7); }
.tone-red { background: linear-gradient(135deg, #f6c9bd, #d77768); }
.tone-gold { background: linear-gradient(135deg, #f8e7bd, #f2b56f); }

.detail-tag {
  position: relative;
  z-index: 1;
  margin-right: 12rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #52796f;
  font-size: 24rpx;
  font-weight: 800;
}

.detail-main {
  margin-top: 20rpx;
  padding: 30rpx;
}

.detail-name {
  color: #27302b;
  font-size: 40rpx;
  font-weight: 800;
}

.detail-price {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff1ec;
  color: #df765d;
  font-size: 34rpx;
  font-weight: 800;
}

.detail-price.special {
  background: #fff4d8;
  color: #c9792e;
}

.detail-note {
  margin-top: 12rpx;
  color: #7b786f;
  font-size: 24rpx;
}

.detail-section {
  padding: 30rpx;
}

.list-item {
  margin-top: 16rpx;
  color: #4c5650;
  font-size: 27rpx;
  line-height: 1.55;
}

.description {
  margin-top: 14rpx;
  color: #4c5650;
  font-size: 27rpx;
  line-height: 1.65;
}
