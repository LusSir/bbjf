<view wx:if="{{product}}" class="page detail-page safe-bottom">
  <view class="detail-cover tone-{{product.imageTone || 'warm'}}">
    <image wx:if="{{product.displayImage}}" class="detail-image" src="{{product.displayImage}}" mode="aspectFill" />
    <view wx:for="{{product.tags}}" wx:key="*this" class="detail-tag">{{item}}</view>
  </view>

  <view class="detail-main card">
    <view class="detail-name">{{product.name}}</view>
    <view class="detail-price {{product.priceType === 'special' ? 'special' : ''}}">{{selectedSku.priceText || product.priceText}}</view>
    <view class="detail-note">{{selectedSku.stockText || '花色、尺寸、库存以门店实物为准'}}</view>
  </view>

  <view class="section card detail-section">
    <view class="section-title">产品卖点</view>
    <view wx:for="{{product.highlights}}" wx:key="*this" class="list-item">{{item}}</view>
  </view>

  <view wx:if="{{product.images && product.images.length}}" class="section card detail-section">
    <view class="section-title">可选花色</view>
    <scroll-view class="color-scroll" scroll-x enable-flex>
      <view wx:for="{{product.images}}" wx:key="url" class="color-card" data-url="{{item.displayUrl}}" bindtap="previewColorImage">
        <image wx:if="{{item.displayUrl}}" class="color-image" src="{{item.displayUrl}}" mode="aspectFill" />
        <view wx:else class="color-image color-image-empty">{{item.name || '花色'}}</view>
        <view class="color-name">{{item.name || '花色图'}}</view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{product.skus && product.skus.length}}" class="section card detail-section">
    <view class="section-title">选择规格</view>
    <view class="sku-grid">
      <view
        wx:for="{{product.skus}}"
        wx:key="id"
        class="sku-card {{selectedSkuId === item.id ? 'active' : ''}} {{item.status === 'disabled' ? 'disabled' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectSku"
      >
        <view class="sku-title">{{item.colorName}}</view>
        <view class="sku-meta">{{item.size || '尺寸到店确认'}}</view>
        <view class="sku-meta">{{item.priceText}}</view>
        <view class="sku-meta">{{item.stockText}}</view>
      </view>
    </view>
    <view class="quantity-line">
      <view class="quantity-label">数量</view>
      <input class="quantity-input" type="number" value="{{quantity}}" bindblur="updateQuantity" />
    </view>
    <view class="cart-actions">
      <button class="cart-button primary" bindtap="addToCart">加入购物车</button>
      <button class="cart-button" bindtap="openCart">去购物车</button>
    </view>
  </view>

  <view class="section card detail-section">
    <view class="section-title">规格信息</view>
    <view wx:for="{{product.specs}}" wx:key="*this" class="list-item">{{item}}</view>
  </view>

  <view class="section card detail-section">
    <view class="section-title">产品说明</view>
    <view class="description">{{product.description}}</view>
  </view>

  <contact-bar />
</view>
