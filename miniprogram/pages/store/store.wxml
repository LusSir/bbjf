<view class="page store-page">
  <view class="store-hero">
    <view class="store-name">{{store.name}}</view>
    <view class="store-slogan">{{store.slogan}}</view>
  </view>

  <view class="quick-actions">
    <view class="quick-action primary" bindtap="handleWechat">
      <view class="action-icon">微</view>
      <view class="action-text">微信咨询</view>
    </view>
    <view class="quick-action" bindtap="handlePhone">
      <view class="action-icon">电</view>
      <view class="action-text">电话联系</view>
    </view>
    <view class="quick-action" bindtap="handleLocation">
      <view class="action-icon">店</view>
      <view class="action-text">导航到店</view>
    </view>
  </view>

  <view class="account-entry card" bindtap="handleAccountEntry">
    <view>
      <view class="account-title">{{isAdmin ? '商铺管理' : (user ? '我的订单' : '登录 / 我的订单')}}</view>
      <view class="account-desc">{{isAdmin ? '管理商品、订单、门店信息和分类' : (user ? '查看已提交的预约订单' : '登录后可提交订单并查看订单状态')}}</view>
    </view>
    <view class="account-badge {{isAdmin ? 'admin' : ''}}">{{isAdmin ? '进入' : (user ? '查看' : '登录')}}</view>
  </view>

  <view class="section card info-card">
    <view class="info-row">
      <view class="info-label">门店地址</view>
      <view class="info-value">{{store.address}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">营业时间</view>
      <view class="info-value">{{store.businessHours}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">联系电话</view>
      <view class="info-value">{{store.phone || '正式发布前补充'}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">微信咨询</view>
      <view class="info-value">{{store.wechatQrCode ? '扫码添加微信咨询' : '正式发布前补充二维码'}}</view>
    </view>
  </view>

  <view class="section card qr-card">
    <view class="section-title">微信咨询</view>
    <view class="qr-content" bindtap="previewWechatQr">
      <image
        wx:if="{{store.displayWechatQrCode}}"
        class="wechat-qr"
        src="{{store.displayWechatQrCode}}"
        mode="aspectFit"
        show-menu-by-longpress="{{true}}"
      />
      <view wx:else class="qr-placeholder">待上传微信二维码</view>
    </view>
    <view class="qr-tip">点击二维码可放大查看，长按图片可保存或识别。</view>
  </view>

  <view class="section card photo-card">
    <view class="section-title">门店实拍</view>
    <scroll-view wx:if="{{store.displayStorePhotos && store.displayStorePhotos.length}}" class="store-photo-list" scroll-x enable-flex>
      <image
        wx:for="{{store.displayStorePhotos}}"
        wx:key="*this"
        class="store-photo"
        src="{{item}}"
        mode="aspectFill"
        data-src="{{item}}"
        bindtap="previewStorePhoto"
      />
    </scroll-view>
    <view wx:else class="store-photo-placeholder">门头 / 店内实拍图后续替换</view>
  </view>

  <view class="section card faq-card">
    <view class="section-title">常见问题</view>
    <view wx:for="{{faqs}}" wx:key="*this" class="faq-item">{{item}}</view>
  </view>
</view>
