<view class="page store-page">
  <view class="store-hero">
    <view class="store-name">{{store.name}}</view>
    <view class="store-slogan">{{store.slogan}}</view>
  </view>

  <view class="quick-actions">
    <button bindtap="handleWechat">微信咨询</button>
    <button bindtap="handlePhone">电话联系</button>
    <button bindtap="handleLocation">导航到店</button>
  </view>

  <view class="section card info-card">
    <view class="info-row">
      <view class="info-label">门店地址</view>
      <view class="info-value">{{store.address}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">营业时间</view>
      <view class="info-value">{{store.businessHours}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">联系电话</view>
      <view class="info-value">{{store.phone || '正式发布前补充'}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">微信咨询</view>
      <view class="info-value">{{store.wechatId || '正式发布前补充'}}</view>
    </view>
  </view>

  <view class="section card photo-card">
    <view class="section-title">门店实拍</view>
    <view class="store-photo">门头 / 店内实拍图后续替换</view>
  </view>

  <view class="section card faq-card">
    <view class="section-title">常见问题</view>
    <view wx:for="{{faqs}}" wx:key="*this" class="faq-item">{{item}}</view>
  </view>
</view>
