.store-page {
  padding-bottom: 48rpx;
}

.store-hero {
  padding: 34rpx;
  border-radius: 16rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #9b3430, #d58a48);
}

.store-name {
  font-size: 44rpx;
  font-weight: 800;
}

.store-slogan {
  margin-top: 12rpx;
  font-size: 26rpx;
  opacity: 0.94;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.quick-actions button {
  height: 82rpx;
  line-height: 82rpx;
  padding: 0;
  border-radius: 12rpx;
  background: #ffffff;
  color: #9b3430;
  font-size: 26rpx;
  font-weight: 700;
}

.quick-actions button::after {
  border: 0;
}

.info-card,
.photo-card,
.faq-card {
  padding: 26rpx;
}

.info-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eee7df;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-label {
  color: #7a7167;
  font-size: 24rpx;
}

.info-value {
  margin-top: 8rpx;
  color: #2f2b27;
  font-size: 28rpx;
  line-height: 1.55;
}

.store-photo {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 260rpx;
  margin-top: 18rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #ead7c5, #b85648);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.faq-item {
  margin-top: 18rpx;
  color: #4a433d;
  font-size: 26rpx;
  line-height: 1.6;
}
