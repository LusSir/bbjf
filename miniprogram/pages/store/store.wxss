.store-page {
  padding-bottom: 56rpx;
}

.store-hero {
  padding: 38rpx;
  border: 1rpx solid rgba(82, 121, 111, 0.12);
  border-radius: 24rpx;
  color: #27302b;
  background:
    linear-gradient(135deg, rgba(247, 181, 160, 0.32), rgba(210, 226, 215, 0.62)),
    #fffdf8;
  box-shadow: 0 18rpx 42rpx rgba(82, 121, 111, 0.1);
}

.store-name {
  font-size: 44rpx;
  font-weight: 800;
}

.store-slogan {
  margin-top: 14rpx;
  color: #50645b;
  font-size: 26rpx;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.quick-actions button {
  height: 86rpx;
  line-height: 86rpx;
  padding: 0;
  border-radius: 18rpx;
  background: #ffffff;
  color: #52796f;
  font-size: 26rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 26rpx rgba(82, 121, 111, 0.08);
}

.quick-actions button::after {
  border: 0;
}

.info-card,
.photo-card,
.faq-card {
  padding: 26rpx;
}

.info-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf0eb;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-label {
  color: #7b786f;
  font-size: 24rpx;
}

.info-value {
  margin-top: 8rpx;
  color: #27302b;
  font-size: 28rpx;
  line-height: 1.55;
}

.store-photo {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 260rpx;
  margin-top: 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #e5efe5, #f8d7c8);
  color: #52796f;
  font-size: 28rpx;
  font-weight: 800;
}

.faq-item {
  margin-top: 18rpx;
  color: #4c5650;
  font-size: 26rpx;
  line-height: 1.6;
}
