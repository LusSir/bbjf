.store-page {
  padding-bottom: 56rpx;
}

.store-hero {
  padding: 38rpx;
  border: 1rpx solid rgba(82, 121, 111, 0.12);
  border-radius: 24rpx;
  color: #27302b;
  background:
    linear-gradient(135deg, rgba(247, 181, 160, 0.32), rgba(210, 226, 215, 0.62)),
    #fffdf8;
  box-shadow: 0 18rpx 42rpx rgba(82, 121, 111, 0.1);
}

.store-name {
  font-size: 44rpx;
  font-weight: 800;
}

.store-slogan {
  margin-top: 14rpx;
  color: #50645b;
  font-size: 26rpx;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  margin-top: 20rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(82, 121, 111, 0.1);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 34rpx rgba(52, 72, 66, 0.08);
}

.quick-action {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 112rpx;
  border-radius: 18rpx;
  color: #52796f;
}

.quick-action + .quick-action::before {
  content: "";
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 1rpx;
  background: #edf0eb;
}

.quick-action.primary {
  background: #eef5ef;
}

.action-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #df765d;
  font-size: 22rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(82, 121, 111, 0.08);
}

.action-text {
  margin-top: 10rpx;
  color: #43564f;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.2;
}

.info-card,
.qr-card,
.photo-card,
.faq-card {
  padding: 26rpx;
}

.info-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf0eb;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-label {
  color: #7b786f;
  font-size: 24rpx;
}

.info-value {
  margin-top: 8rpx;
  color: #27302b;
  font-size: 28rpx;
  line-height: 1.55;
}

.qr-content {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 320rpx;
  margin-top: 22rpx;
  border-radius: 20rpx;
  background: #f8f7f3;
}

.wechat-qr {
  width: 280rpx;
  height: 280rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(52, 72, 66, 0.08);
}

.qr-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 280rpx;
  height: 280rpx;
  border: 2rpx dashed rgba(82, 121, 111, 0.28);
  border-radius: 18rpx;
  color: #52796f;
  font-size: 26rpx;
  font-weight: 800;
}

.qr-tip {
  margin-top: 16rpx;
  color: #7b786f;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: center;
}

.store-photo {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 260rpx;
  margin-top: 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #e5efe5, #f8d7c8);
  color: #52796f;
  font-size: 28rpx;
  font-weight: 800;
}

.faq-item {
  margin-top: 18rpx;
  color: #4c5650;
  font-size: 26rpx;
  line-height: 1.6;
}
