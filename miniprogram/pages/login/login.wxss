.login-page {
  padding-top: 80rpx;
}

.login-card {
  padding: 38rpx;
}

.login-title {
  color: #26302a;
  font-size: 42rpx;
  font-weight: 900;
}

.login-desc {
  margin-top: 16rpx;
  color: #5f6f66;
  font-size: 26rpx;
  line-height: 1.6;
}

.user-panel {
  margin-top: 30rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #f4f6f1;
}

.status-pill {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #e8f0e9;
  color: #4f7669;
  font-size: 24rpx;
  font-weight: 800;
}

.status-pill.admin {
  background: #fff0eb;
  color: #d96f57;
}

.openid-text {
  margin-top: 16rpx;
  color: #6f7a72;
  font-size: 22rpx;
  line-height: 1.5;
  word-break: break-all;
}

.user-name {
  margin-top: 16rpx;
  color: #26302a;
  font-size: 26rpx;
  font-weight: 800;
}

.primary-button,
.secondary-button,
.logout-button {
  margin-top: 30rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.primary-button {
  color: #ffffff;
  background: #4f7669;
}

.secondary-button {
  color: #4f7669;
  background: #e8f0e9;
}

.logout-button {
  color: #d96f57;
  background: #fff0eb;
}
