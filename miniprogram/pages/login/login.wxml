<view class="page login-page">
  <view class="login-card card">
    <view class="login-title">贝贝家纺</view>
    <view class="login-desc">登录后可提交预约订单、查看我的订单；管理员会额外显示商铺管理入口。</view>

    <view wx:if="{{user}}" class="user-panel">
      <view class="status-pill {{isAdmin ? 'admin' : ''}}">
        {{isAdmin ? '管理员' : '普通用户'}}
      </view>
      <view wx:if="{{user.nickName}}" class="user-name">微信昵称：{{user.nickName}}</view>
      <view class="openid-text">OpenID：{{user.openid}}</view>
    </view>

    <button class="primary-button" loading="{{loading}}" bindtap="handleLogin">
      {{user ? '刷新微信资料' : '授权并登录'}}
    </button>

    <button wx:if="{{user}}" class="secondary-button" bindtap="openMyOrders">
      查看我的订单
    </button>

    <button wx:if="{{isAdmin}}" class="secondary-button" bindtap="openAdmin">
      进入商铺管理
    </button>

    <button wx:if="{{user}}" class="logout-button" bindtap="handleLogout">
      退出登录
    </button>
  </view>
</view>
