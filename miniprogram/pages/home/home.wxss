.home-page {
  padding-bottom: 56rpx;
}

.hero {
  min-height: 270rpx;
  padding: 38rpx;
  border: 1rpx solid rgba(82, 121, 111, 0.12);
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(247, 181, 160, 0.32), rgba(210, 226, 215, 0.62)),
    #fffdf8;
  color: #27302b;
  box-shadow: 0 18rpx 42rpx rgba(82, 121, 111, 0.1);
}

.store-name {
  font-size: 50rpx;
  font-weight: 800;
}

.store-slogan {
  margin-top: 14rpx;
  color: #50645b;
  font-size: 26rpx;
}

.hero-note {
  display: inline-flex;
  margin-top: 44rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #6b6259;
  font-size: 24rpx;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  margin-top: 20rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(82, 121, 111, 0.1);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 34rpx rgba(52, 72, 66, 0.08);
}

.quick-action {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 112rpx;
  border-radius: 18rpx;
  color: #52796f;
}

.quick-action + .quick-action::before {
  content: "";
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 1rpx;
  background: #edf0eb;
}

.quick-action.primary {
  background: #eef5ef;
}

.action-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #df765d;
  font-size: 22rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(82, 121, 111, 0.08);
}

.action-text {
  margin-top: 10rpx;
  color: #43564f;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.2;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.category-card {
  position: relative;
  min-height: 132rpx;
  padding: 24rpx;
  overflow: hidden;
}

.category-card::after {
  content: "";
  position: absolute;
  right: -20rpx;
  bottom: -24rpx;
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: rgba(247, 181, 160, 0.28);
}

.category-name {
  position: relative;
  z-index: 1;
  color: #27302b;
  font-size: 30rpx;
  font-weight: 800;
}

.category-desc {
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  color: #7b786f;
  font-size: 23rpx;
  line-height: 1.45;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}
