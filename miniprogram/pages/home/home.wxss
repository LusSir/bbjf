.home-page {
  padding-bottom: 56rpx;
}

.hero {
  min-height: 270rpx;
  padding: 38rpx;
  border: 1rpx solid rgba(82, 121, 111, 0.12);
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(247, 181, 160, 0.32), rgba(210, 226, 215, 0.62)),
    #fffdf8;
  color: #27302b;
  box-shadow: 0 18rpx 42rpx rgba(82, 121, 111, 0.1);
}

.store-name {
  font-size: 50rpx;
  font-weight: 800;
}

.store-slogan {
  margin-top: 14rpx;
  color: #50645b;
  font-size: 26rpx;
}

.hero-note {
  display: inline-flex;
  margin-top: 44rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #6b6259;
  font-size: 24rpx;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.quick-actions button {
  height: 86rpx;
  line-height: 86rpx;
  padding: 0;
  border-radius: 18rpx;
  background: #ffffff;
  color: #52796f;
  font-size: 26rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 26rpx rgba(82, 121, 111, 0.08);
}

.quick-actions button::after {
  border: 0;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.category-card {
  position: relative;
  min-height: 132rpx;
  padding: 24rpx;
  overflow: hidden;
}

.category-card::after {
  content: "";
  position: absolute;
  right: -20rpx;
  bottom: -24rpx;
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: rgba(247, 181, 160, 0.28);
}

.category-name {
  position: relative;
  z-index: 1;
  color: #27302b;
  font-size: 30rpx;
  font-weight: 800;
}

.category-desc {
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  color: #7b786f;
  font-size: 23rpx;
  line-height: 1.45;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}
