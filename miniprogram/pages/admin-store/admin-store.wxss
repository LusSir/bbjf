.admin-store-page {
  padding-bottom: 56rpx;
}

.state-card,
.form-card {
  padding: 34rpx;
}

.state-title,
.section-title {
  color: #27302b;
  font-size: 34rpx;
  font-weight: 900;
}

.state-desc {
  margin-top: 12rpx;
  color: #69746e;
  font-size: 25rpx;
  line-height: 1.5;
}

.form-field {
  margin-top: 24rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #4c5650;
  font-size: 25rpx;
  font-weight: 800;
}

.field-input,
.field-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #f8f7f3;
  color: #27302b;
  font-size: 26rpx;
}

.field-input {
  min-height: 84rpx;
  padding: 0 22rpx;
}

.field-textarea {
  min-height: 150rpx;
  padding: 18rpx 22rpx;
  line-height: 1.5;
}

.field-textarea.compact {
  min-height: 104rpx;
}

.coord-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.image-edit-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.qr-preview,
.image-empty {
  width: 150rpx;
  height: 150rpx;
  border-radius: 18rpx;
  background: #f8f7f3;
}

.image-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7b786f;
  font-size: 25rpx;
}

.image-empty.wide {
  width: 100%;
  height: 110rpx;
  margin-top: 16rpx;
}

.small-button,
.tiny-button {
  margin: 0;
  border-radius: 14rpx;
  color: #52796f;
  background: #eef5ef;
  font-size: 24rpx;
  font-weight: 800;
}

.inline-button {
  width: 220rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 16rpx;
}

.photo-item {
  min-width: 0;
}

.photo-preview {
  width: 100%;
  height: 132rpx;
  border-radius: 16rpx;
  background: #f8f7f3;
}

.tiny-button {
  width: 100%;
  margin-top: 8rpx;
  line-height: 50rpx;
}

.tiny-button.danger {
  color: #df765d;
  background: #fff1ec;
}

.primary-button {
  margin-top: 30rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: #52796f;
  font-size: 28rpx;
  font-weight: 800;
}
