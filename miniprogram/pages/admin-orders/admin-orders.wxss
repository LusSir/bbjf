.admin-orders-page {
  padding-bottom: 56rpx;
}

.state-card,
.order-card {
  padding: 30rpx;
  margin-top: 18rpx;
}

.state-title,
.order-title {
  color: #24352e;
  font-size: 30rpx;
  font-weight: 900;
}

.state-desc,
.summary-text,
.order-meta,
.note-line,
.item-meta,
.preview-line,
.more-line {
  margin-top: 8rpx;
  color: #6f7a72;
  font-size: 24rpx;
  line-height: 1.45;
}

.order-card:active {
  transform: translateY(2rpx);
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.filter-pill {
  min-width: 210rpx;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  color: #4f7669;
  background: #eaf3ed;
  font-size: 25rpx;
  font-weight: 900;
  text-align: center;
}

.order-item {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #e5ece6;
}

.item-thumb {
  width: 120rpx;
  height: 96rpx;
  border-radius: 14rpx;
  background: #f4f6f1;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-name {
  color: #24352e;
  font-size: 26rpx;
  font-weight: 900;
}

.preview-line {
  padding: 10rpx 0;
  border-top: 1rpx solid rgba(79, 118, 105, 0.1);
}

.more-line {
  color: #4f7669;
  font-weight: 800;
}

.status-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.mini-button {
  margin: 0;
  padding: 0 18rpx;
  border-radius: 14rpx;
  color: #4f7669;
  background: #eaf3ed;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 54rpx;
}

.mini-button.active {
  color: #ffffff;
  background: #4f7669;
}
