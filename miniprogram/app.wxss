page {
  background: #f7f4ef;
  color: #252525;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.section {
  margin-top: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2f2b27;
}

.section-link {
  font-size: 24rpx;
  color: #9b3430;
}

.card {
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 10rpx 28rpx rgba(58, 45, 35, 0.08);
}

.muted {
  color: #7a7167;
}

.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
