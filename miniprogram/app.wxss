page {
  background: #f8f7f3;
  color: #232824;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.section {
  margin-top: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #27302b;
}

.section-link {
  font-size: 24rpx;
  color: #52796f;
  font-weight: 700;
}

.card {
  background: #ffffff;
  border: 1rpx solid rgba(82, 121, 111, 0.1);
  border-radius: 18rpx;
  box-shadow: 0 12rpx 34rpx rgba(52, 72, 66, 0.07);
}

.muted {
  color: #7b786f;
}

.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
