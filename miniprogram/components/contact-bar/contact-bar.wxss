.contact-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  padding: 16rpx 22rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(248, 247, 243, 0.9);
  border-top: 1rpx solid rgba(82, 121, 111, 0.08);
  box-shadow: 0 -14rpx 36rpx rgba(52, 72, 66, 0.12);
  backdrop-filter: blur(18rpx);
}

.contact-button {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  color: #52796f;
}

.contact-button + .contact-button::before {
  content: "";
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 1rpx;
  background: #e3ebe4;
}

.contact-button.primary {
  border-radius: 20rpx;
  background: linear-gradient(135deg, #f3a691, #df765d);
  color: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(223, 118, 93, 0.24);
}

.contact-button.primary::before {
  display: none;
}

.contact-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  margin-right: 10rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #df765d;
  font-size: 20rpx;
  font-weight: 900;
}

.contact-button:not(.primary) .contact-icon {
  background: #eef5ef;
  color: #52796f;
}

.contact-text {
  font-size: 25rpx;
  font-weight: 850;
  line-height: 1.2;
}
