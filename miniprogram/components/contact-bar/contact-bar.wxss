.contact-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: grid;
  grid-template-columns: 1.2fr 1fr 1fr;
  gap: 14rpx;
  padding: 18rpx 20rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  border-top: 1rpx solid rgba(82, 121, 111, 0.1);
  box-shadow: 0 -12rpx 32rpx rgba(52, 72, 66, 0.1);
}

.contact-button {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0;
  border-radius: 18rpx;
  background: #eef4ef;
  color: #52796f;
  font-size: 26rpx;
  font-weight: 800;
}

.contact-button::after {
  border: 0;
}

.contact-button.primary {
  background: linear-gradient(135deg, #f2a58f, #df765d);
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(223, 118, 93, 0.25);
}
