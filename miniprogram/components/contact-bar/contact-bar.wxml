<view class="contact-bar">
  <view class="contact-button primary" bindtap="handleWechat">
    <view class="contact-icon">微</view>
    <view class="contact-text">微信咨询</view>
  </view>
  <view class="contact-button" bindtap="handlePhone">
    <view class="contact-icon">电</view>
    <view class="contact-text">电话联系</view>
  </view>
  <view class="contact-button" bindtap="handleLocation">
    <view class="contact-icon">店</view>
    <view class="contact-text">导航到店</view>
  </view>
</view>
