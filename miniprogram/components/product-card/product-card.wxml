<view class="product-card card" bindtap="handleTap">
  <view class="product-cover tone-{{product.imageTone || 'warm'}} {{product.image ? 'has-image' : ''}}">
    <image wx:if="{{product.image}}" class="product-image" src="{{product.image}}" mode="aspectFill" />
    <text wx:if="{{product.tags && product.tags.length}}" class="tag">{{product.tags[0]}}</text>
  </view>
  <view class="product-info">
    <view class="product-name">{{product.name}}</view>
    <view class="product-highlights">{{product.highlights[0]}}</view>
    <view class="product-price {{product.priceType === 'special' ? 'special' : ''}}">{{product.priceText}}</view>
  </view>
</view>
