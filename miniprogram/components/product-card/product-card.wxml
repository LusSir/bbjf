<view class="product-card card" bindtap="handleTap">
  <view class="product-cover tone-{{product.imageTone || 'warm'}} {{displayImage ? 'has-image' : ''}}">
    <image wx:if="{{displayImage}}" class="product-image" src="{{displayImage}}" mode="aspectFill" />
    <text wx:if="{{product.tags && product.tags.length}}" class="tag">{{product.tags[0]}}</text>
  </view>
  <view class="product-info">
    <view class="product-name">{{product.name}}</view>
    <view class="product-highlights">{{product.highlights[0]}}</view>
    <view class="product-price {{product.priceType === 'special' ? 'special' : ''}}">{{displaySku.priceText || product.priceText}}</view>
    <view wx:if="{{displaySku.stockText}}" class="product-stock">{{displaySku.stockText}}</view>
  </view>
</view>
