.product-card {
  overflow: hidden;
  transition: transform 0.18s ease;
}

.product-cover {
  position: relative;
  height: 188rpx;
  overflow: hidden;
}

.tone-warm { background: linear-gradient(135deg, #f8d7c8, #e9efe7); }
.tone-deep { background: linear-gradient(135deg, #dfe9df, #86a99d); }
.tone-soft { background: linear-gradient(135deg, #f8e3de, #f3b7a6); }
.tone-rose { background: linear-gradient(135deg, #f7d8d0, #d99b9a); }
.tone-green { background: linear-gradient(135deg, #e5efe5, #91b3a7); }
.tone-red { background: linear-gradient(135deg, #f6c9bd, #d77768); }
.tone-gold { background: linear-gradient(135deg, #f8e7bd, #f2b56f); }

.product-cover::after {
  content: "";
  position: absolute;
  right: -36rpx;
  bottom: -42rpx;
  width: 126rpx;
  height: 126rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.36);
}

.product-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.product-cover.has-image::after {
  display: none;
}

.tag {
  position: absolute;
  top: 14rpx;
  left: 14rpx;
  z-index: 1;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #52796f;
  font-size: 22rpx;
  font-weight: 800;
}

.product-info {
  padding: 18rpx;
}

.product-name {
  color: #27302b;
  font-size: 28rpx;
  font-weight: 800;
}

.product-highlights {
  margin-top: 8rpx;
  color: #7b786f;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-price {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #fff1ec;
  color: #df765d;
  font-size: 26rpx;
  font-weight: 800;
}

.product-price.special {
  background: #fff4d8;
  color: #c9792e;
}
