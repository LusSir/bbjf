.product-card {
  min-width: 0;
  overflow: hidden;
  transition: transform 0.18s ease;
}

.product-card:active {
  transform: translateY(2rpx);
}

.product-cover {
  position: relative;
  width: 100%;
  min-width: 0;
  height: 196rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.tone-warm { background: linear-gradient(135deg, #f5ddd1, #e7efe7); }
.tone-deep { background: linear-gradient(135deg, #dfe8dc, #7fa396); }
.tone-soft { background: linear-gradient(135deg, #f7e4dd, #e9b9a9); }
.tone-rose { background: linear-gradient(135deg, #f4d9d3, #c99392); }
.tone-green { background: linear-gradient(135deg, #e2ede2, #8ea99d); }
.tone-red { background: linear-gradient(135deg, #f3cbc0, #cc7567); }
.tone-gold { background: linear-gradient(135deg, #f5e4bd, #e4b06f); }

.product-cover::after {
  content: "";
  position: absolute;
  right: -36rpx;
  bottom: -42rpx;
  width: 126rpx;
  height: 126rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.34);
}

.product-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.product-cover.has-image::after {
  display: none;
}

.tag {
  position: absolute;
  top: 14rpx;
  left: 14rpx;
  z-index: 1;
  max-width: 80%;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.84);
  color: #4f7669;
  font-size: 22rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.product-info {
  min-width: 0;
  padding: 18rpx;
}

.product-name {
  color: #26302a;
  font-size: 28rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-highlights {
  margin-top: 8rpx;
  color: #6f7a72;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-price {
  display: inline-block;
  max-width: 100%;
  box-sizing: border-box;
  margin-top: 14rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #fff0eb;
  color: #d96f57;
  font-size: 26rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price.special {
  background: #fff4d8;
  color: #b86f26;
}

.product-stock {
  margin-top: 8rpx;
  color: #7c877f;
  font-size: 22rpx;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
