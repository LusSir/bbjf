.product-card {
  overflow: hidden;
}

.product-cover {
  position: relative;
  height: 180rpx;
}

.tone-warm { background: linear-gradient(135deg, #ead7c5, #b85648); }
.tone-deep { background: linear-gradient(135deg, #d6c4a8, #6f3f2c); }
.tone-soft { background: linear-gradient(135deg, #f2dedc, #c87982); }
.tone-rose { background: linear-gradient(135deg, #f1c7c0, #a94c5a); }
.tone-green { background: linear-gradient(135deg, #d8e5cf, #5e8f74); }
.tone-red { background: linear-gradient(135deg, #e3a09a, #9b3430); }
.tone-gold { background: linear-gradient(135deg, #edd59d, #c8872d); }

.tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #9b3430;
  font-size: 22rpx;
  font-weight: 700;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  color: #2f2b27;
  font-size: 28rpx;
  font-weight: 700;
}

.product-highlights {
  margin-top: 8rpx;
  color: #7a7167;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-price {
  margin-top: 12rpx;
  color: #9b3430;
  font-size: 26rpx;
  font-weight: 700;
}

.product-price.special {
  color: #c46a20;
}
